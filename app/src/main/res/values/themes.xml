<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EmojiChanger" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorPrimaryVariant">@color/ios_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ios_purple</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorError">@color/ios_red</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.EmojiChanger.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_emoji_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.EmojiChanger</item>
    </style>

    <!-- Big Apply Button -->
    <style name="Widget.EmojiChanger.Button.Apply" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="backgroundTint">@color/ios_blue</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <!-- Status card -->
    <style name="Widget.EmojiChanger.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Section header text -->
    <style name="TextAppearance.EmojiChanger.SectionHeader" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/ios_gray</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
